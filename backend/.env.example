# Copy this to .env and fill in your values
# Never commit .env to version control

DEBUG=True
SECRET_KEY=your-secret-key-here-generate-one-with-python-secrets

# Local development (SQLite fallback if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/esg_platform

# Production only — whitelist your Vercel domain
CORS_ALLOWED_ORIGINS=http://localhost:5173

# For production on Render, override with:
# DJANGO_SETTINGS_MODULE=config.settings.production
